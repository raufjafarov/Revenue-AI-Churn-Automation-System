      "parameters": {
        "jsCode": "// AI Agent1-in string output-unu JSON-a parse edirik\nconst raw = $input.first().json.output;\nconst customer = $('Get Customer Data').first().json;\n\nlet strategy;\ntry {\n  strategy = JSON.parse(raw.replace(/```json|```/g, '').trim());\n} catch (e) {\n  strategy = {\n    strategy_summary: 'Manual review',\n    message_az: raw,\n    offer_type: 'custom',\n    offer_value: 'N/A',\n    follow_up_days: 3,\n    escalation_needed: true\n  };\n}\n\nreturn [{\n  json: {\n    ...strategy,\n    customer_name: customer.name,\n    customer_email: customer.email,\n    customer_phone: customer.phone,\n    customer_company: customer.company,\n    customer_id: customer.customer_id\n  }\n}];"
      },
